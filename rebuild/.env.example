# ─── Claw_Rising Rebuild — Environment Template ─────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file powers both the Docker deployment and the native WSL environment.
# Variables are sourced by docker-compose.yml (env_file) and by the gateway
# service (EnvironmentFile).
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED — API Keys
# ═══════════════════════════════════════════════════════════════════════════

# DeepSeek API key — primary LLM provider for OpenClaw
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# Replicate API token — used by Gallery sync + Wallpaper Bot image generation
# Get yours at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — Additional API Keys
# ═══════════════════════════════════════════════════════════════════════════

# Google Gemini API key — vision model for Pantry Pilot photo analysis
# Get yours at: https://ai.google.dev/
# GOOGLE_API_KEY=AIzaSy...

# ═══════════════════════════════════════════════════════════════════════════
# OpenClaw Gateway
# ═══════════════════════════════════════════════════════════════════════════

# Port the gateway listens on (default: 19000)
OPENCLAW_GATEWAY_PORT=19000

# Gateway mode: local | relay (default: local)
# OPENCLAW_GATEWAY_MODE=local

# Logging level: trace | debug | info | warn | error (default: info)
# OPENCLAW_LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════
# Telegram Bots
# ═══════════════════════════════════════════════════════════════════════════

# Primary bot token (main agent)
# Get from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# Draper agent bot token (secondary agent)
# TELEGRAM_DRAPER_TOKEN=8272729979:AAEP...

# ═══════════════════════════════════════════════════════════════════════════
# Gallery (FastAPI Backend + Next.js Frontend)
# ═══════════════════════════════════════════════════════════════════════════

# Gallery database path (SQLite)
# GALLERY_DB_PATH=/home/samuel/projects/gallery/gallery.db

# ngrok auth token (for Gallery tunnel — optional)
# NGROK_AUTH_TOKEN=your_ngrok_auth_token

# ═══════════════════════════════════════════════════════════════════════════
# Deployment
# ═══════════════════════════════════════════════════════════════════════════

# Deployment mode: staging | prod
# MODE=staging

# Timezone for logs and cron scheduling
TZ=Pacific/Auckland

# ═══════════════════════════════════════════════════════════════════════════
# Wallpaper Bot
# ═══════════════════════════════════════════════════════════════════════════

# Replicate model version for SDXL wallpaper generation
# WALLPAPER_MODEL=stability-ai/sdxl:39ed52f2a78e...

# ═══════════════════════════════════════════════════════════════════════════
# Email (optional — himalaya / IMAP for Charleston rental inbox)
# ═══════════════════════════════════════════════════════════════════════════

# IMAP_SERVER=imap.gmail.com
# IMAP_USER=your_email@gmail.com
# IMAP_PASS=your_app_password

# ═══════════════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. Keep this file OUT of version control — add .env to .gitignore.
# 2. For Docker, secrets can alternatively be mounted via Docker Secrets
#    instead of .env. See: https://docs.docker.com/engine/swarm/secrets/
# 3. The Dockerfile reads .env automatically via ENV_FILE in compose.
# 4. OpenClaw's openclaw.json references ${VARIABLE} for env substitution.
